server:
    rundir: "/run/knot"
    user: knot:knot
    listen: [ 0.0.0.0@53, ::@53 ]

log:
  - target: stderr
    any: error
  - target: /var/log/knot-query/knot-query.log
    any: info

mod-stats:
  - id: custom
    request-protocol: on
    server-operation: on
    request-bytes: on
    response-bytes: on
    response-code: on
    query-type: on

template:
  - id: default
    storage: "/var/lib/knot"
    file: "%s.zone"
    global-module: mod-stats/custom

database:
    storage: "/var/log/knot-query"

# Example zones — replace with your own zone data.
# The zones below are AS112 reference zones provided as a working example.
# See https://www.as112.net/ for AS112 project details.
zone:
  - domain: 10.in-addr.arpa
    file: db.dd-empty
  - domain: 16.172.in-addr.arpa
    file: db.dd-empty
  - domain: 17.172.in-addr.arpa
    file: db.dd-empty
  - domain: 18.172.in-addr.arpa
    file: db.dd-empty
  - domain: 19.172.in-addr.arpa
